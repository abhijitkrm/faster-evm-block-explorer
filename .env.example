# ============================================================
# Faster EVM Block Explorer — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# Your chain's HTTP JSON-RPC endpoint (required)
RPC_URL=http://your-rpc-node:8545/

# Database credentials
DB_USER=explorer
DB_PASSWORD=change_me
DB_NAME=explorer

# API base URL as seen from the browser (used by the frontend build)
VITE_API_URL=http://localhost:3000

# Logging level for all services: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Indexer tuning (optional)
BATCH_SIZE=100       # messages read from Redis per iteration
DB_POOL_MAX=20       # max Postgres connections in the indexer pool
